# T09 — GTX 1060 3GB처럼 VRAM이 작은 GPU용 num_ctx 고정 모델 정의
#
# qwen2.5(7B, 4.7GB)는 3GB VRAM에 올라가지 않아 qwen2.5:3b(1.9GB)를 사용한다.
# num_ctx 함정은 동일하게 적용되므로 컨텍스트를 12288로 고정한다.
#
# 사용법:
#   ollama pull qwen2.5:3b
#   ollama create qwen2.5-3b-ctx12k -f ollama/Modelfile.qwen2.5-3b-ctx12k

FROM qwen2.5:3b

PARAMETER num_ctx 12288
